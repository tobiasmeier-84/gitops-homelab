# This is an EXAMPLE showing the expected shape only — not a real secret.
# The actual file (root-password.enc.yaml, no .example suffix) must be
# created with `sops secrets/root-password.enc.yaml` so it's encrypted
# on save, per .sops.yaml's path_regex rule for this repo.
#
# Generate the hash with: openssl passwd -6
# (creates a SHA-512 crypt hash, which is what Proxmox's answer file expects)

root_password_hash: "$6$examplesaltvalue$doNotUseThisRealHashItIsJustAnExample"